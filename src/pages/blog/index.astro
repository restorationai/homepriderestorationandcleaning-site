---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import CtaBanner from "~/components/CtaBanner.astro";
import { brand } from "~/lib/brand";

const index = await getEntry("pages", "blog-index");
const posts = (await getCollection("blog"))
  .sort((a, b) => (b.data.published_at || "").localeCompare(a.data.published_at || ""));

const title = index?.data.title ?? "Blog";
const meta = index?.data.meta_description ?? "";
const breadcrumb = index?.data.breadcrumb;
const heroImage = index?.data.hero || `${brand.imagesBase}/brand/hero.webp`;
---

<BaseLayout
  title={title}
  meta_description={meta}
  hero_image_url={heroImage}
  schema_stubs={["website", "breadcrumb-list"]}
  schema_ctx={{ archetype: "blog-index" }}
  breadcrumb={breadcrumb}
>
  <!-- HEADER -->
  <section class="relative min-h-[350px] flex items-center overflow-hidden bg-navy border-b border-white/10">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt="" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-navy via-navy/90 to-navy/60"></div>
    </div>
    <div class="container-wide relative z-10 py-16">
      <div class="max-w-2xl">
        <div class="eyebrow">Resources</div>
        <h1>{index?.data.h1 ?? "Restoration Resources"}</h1>
        <p class="text-lg text-white/85 mt-6 mb-0 leading-relaxed">{meta}</p>
      </div>
    </div>
  </section>

  <!-- POST GRID -->
  <section class="section-first bg-navy pb-24">
    <div class="container-wide">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}/`} class="group block rounded-lg border border-white/10 bg-white/5 hover:bg-white/10 hover:border-primary/40 transition-all overflow-hidden no-underline">
            {post.data.hero && (
              <div class="aspect-[16/9] overflow-hidden bg-navy-900">
                <img src={post.data.hero} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
            )}
            <div class="p-6">
              <div class="text-xs font-black uppercase tracking-widest text-primary-200 mb-3">
                {new Date(post.data.published_at).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </div>
              <h2 class="text-xl text-white mt-0 mb-3 leading-snug">{post.data.title}</h2>
              <p class="text-sm text-white/65 mb-0 leading-relaxed">{post.data.meta_description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner heading="Need help instead of reading?" subheading="We answer the phone 24/7." />
</BaseLayout>
