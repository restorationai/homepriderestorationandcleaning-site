---
import { getEntry, getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import CtaBanner from "~/components/CtaBanner.astro";
import FAQSection from "~/components/FAQSection.astro";
import InternalLinks from "~/components/InternalLinks.astro";
import Hero from "~/components/ui/Hero.astro";
import TrustStrip from "~/components/ui/TrustStrip.astro";
import AboutSection from "~/components/ui/AboutSection.astro";
import ServicesStrip from "~/components/ui/ServicesStrip.astro";
import ProcessSection from "~/components/ui/ProcessSection.astro";
import BeforeAfterSection from "~/components/ui/BeforeAfterSection.astro";
import ServiceAreasSection from "~/components/ui/ServiceAreasSection.astro";
import { brand } from "~/lib/brand";
import { workPairs } from "~/data/work";

const entry = await getEntry("pages", "home");
if (!entry) throw new Error("Missing content: pages/home.md — has Skill 3 rendered yet?");
const { Content } = await entry.render();
const data = entry.data;

const heroImage = data.hero || `${brand.imagesBase}/brand/hero.webp`;

// Pull top 6 services by priority for the home page strip
const allServices = await getCollection("services");
const services = (allServices as CollectionEntry<"services">[])
  .sort((a, b) => (b.data.priority || 0) - (a.data.priority || 0))
  .slice(0, 6);
---

<BaseLayout
  title={data.title}
  meta_description={data.meta_description}
  hero_image_url={heroImage}
  schema_stubs={["organization", "website", "local-business"]}
  schema_ctx={{ archetype: "home" }}
  faq={data.faq}
>
  <Hero title={data.h1} subtitle={data.meta_description} backgroundImage="/images/hero-bg.webp" />

  <TrustStrip />

  <AboutSection imageSrc="/images/team.webp" imageAlt={`${brand.displayName} Team`}>
    <p>
      {brand.displayName} has been serving {brand.primaryCity} and the surrounding {brand.primaryState} area since {brand.foundedYear}. We specialize in rapid-response disaster restoration—handling everything from water and fire damage to biohazard cleanup and full reconstruction. When disaster strikes, our certified professionals are standing by 24/7 to return your property to its pre-loss condition quickly and safely.
    </p>
  </AboutSection>

  {services.length > 0 && <ServicesStrip services={services} />}

  <ProcessSection />

  <BeforeAfterSection pairs={workPairs} />

  <CtaBanner heading="24/7 Emergency Response" subheading="We answer the phone day and night. Insurance billing accepted." />

  <FAQSection faq={data.faq} />

  <ServiceAreasSection />

  <section class="bg-dark py-20 border-t border-white/10">
    <div class="container-wide max-w-6xl mx-auto prose prose-xl prose-invert prose-headings:font-black prose-headings:uppercase prose-headings:tracking-tighter prose-a:text-primary-500 text-white/70">
      <Content />
    </div>
  </section>

  <InternalLinks paths={data.internal_links} heading="Where to Next" />
</BaseLayout>
