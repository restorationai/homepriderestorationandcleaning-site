---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { brand } from "~/lib/brand";
---

<BaseLayout
  title={`Page Not Found | ${brand.displayName}`}
  meta_description="The page you're looking for doesn't exist."
  noindex={true}
>
  <section class="min-h-[70vh] flex items-center justify-center bg-navy">
    <div class="container-wide text-center max-w-2xl">
      <div class="text-8xl md:text-9xl font-display font-black text-primary-200">404</div>
      <h1 class="mt-6">Page Not Found</h1>
      <p class="mt-4 text-lg text-white/70 mb-10">The page you're looking for has moved or doesn't exist.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary">Back to Home</a>
        <a href="/services/" class="btn-outline">See All Services</a>
      </div>
    </div>
  </section>
</BaseLayout>
