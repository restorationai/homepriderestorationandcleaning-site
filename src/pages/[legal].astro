---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("legal");
  return entries.map((e) => ({ params: { legal: e.data.ref }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
---

<BaseLayout
  title={data.title}
  meta_description={data.meta_description}
  schema_stubs={["breadcrumb-list"]}
  schema_ctx={{ archetype: "legal" }}
  breadcrumb={data.breadcrumb}
>
  <section class="section-first bg-navy">
    <div class="container-wide max-w-3xl mx-auto">
      <div class="eyebrow">Legal</div>
      <h1 class="mb-12">{data.h1}</h1>
      <div class="prose-body">
        <Content />
      </div>
    </div>
  </section>
</BaseLayout>
