---
import { ArrowRight } from '@lucide/astro';
import { brand } from '~/lib/brand';

const photos = [
  { src: "/images/gallery/img1.webp", alt: `${brand.displayName} project photo 1` },
  { src: "/images/gallery/img2.webp", alt: `${brand.displayName} project photo 2` },
  { src: "/images/gallery/img3.webp", alt: `${brand.displayName} project photo 3` },
  { src: "/images/gallery/img4.webp", alt: `${brand.displayName} project photo 4` },
  { src: "/images/gallery/img5.webp", alt: `${brand.displayName} project photo 5` },
  { src: "/images/gallery/img6.webp", alt: `${brand.displayName} project photo 6` },
];
---

<section class="bg-dark py-24 text-white">
  <div class="container-wide px-6 sm:px-10 lg:px-12">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8">
      <div>
        <span class="inline-block bg-black text-white px-4 py-1.5 text-xs font-black uppercase tracking-[0.3em] mb-4">See why our customers love us</span>
        <div class="flex items-center gap-6">
          <h2 class="text-5xl md:text-6xl font-black uppercase tracking-tighter">Our Work</h2>
          <div class="hidden md:block flex-grow h-px bg-white/30 w-72"></div>
        </div>
      </div>
      <a 
        href="#"
        class="bg-white text-dark font-black uppercase px-8 py-4 text-base flex items-center justify-center gap-3 hover:bg-primary-600 hover:text-white transition-all rounded-sm shadow-xl"
      >
        See All Photos <ArrowRight size={20} />
      </a>
    </div>

    <div class="columns-1 sm:columns-2 lg:columns-3 gap-6 space-y-6">
      {photos.map((photo, i) => (
        <div class="break-inside-avoid overflow-hidden rounded-sm border-4 border-white/10 shadow-2xl group transition-all duration-500 hover:border-primary-500">
          <img 
            src={photo.src} 
            alt={photo.alt} 
            class="w-full h-auto transition-all duration-700 transform group-hover:scale-105" 
            referrerpolicy="no-referrer"
          />
        </div>
      ))}
    </div>
  </div>
</section>
