---
// src/components/ui/Hero.astro
import { brand } from "~/lib/brand";
import { Phone } from "@lucide/astro";

interface Props {
  title: string;
  subtitle?: string;
  isSensitive?: boolean;
  backgroundImage?: string;
}

const { title, subtitle, isSensitive = false, backgroundImage } = Astro.props;
---

<header class="relative overflow-hidden border-t border-white/10 min-h-[78vh] md:min-h-[80vh] flex items-center">
  {backgroundImage ? (
    <div class="absolute inset-0 z-0">
      <img src={backgroundImage} alt="Background" class="w-full h-full object-cover object-[center_35%]" />
      <div class="absolute inset-0 bg-dark-900/40"></div>
    </div>
  ) : (
    <div class="absolute inset-0 bg-dark z-0"></div>
  )}

  <div class="absolute inset-0 bg-gradient-to-br from-dark-900/60 to-dark-800/40 z-0"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-white/5 to-transparent z-0"></div>

  <div class="container-wide relative z-10 pt-10 pb-14 md:pt-12 md:pb-16 text-left">
    <div class="max-w-xl">
      <h1 class="mb-6 drop-shadow-lg text-4xl md:text-5xl lg:text-6xl">{title}</h1>
      {subtitle && <p class="text-xl md:text-2xl text-white/90 mb-10 drop-shadow-md">{subtitle}</p>}
      <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center flex-wrap">
        <a
          href={`tel:${brand.phoneRaw}`}
          class={`group inline-flex flex-col items-center justify-center rounded-xl shadow-[0_0_40px_rgba(249,115,22,0.4)] px-8 py-3 transition-transform hover:-translate-y-1 border-2 border-white ${isSensitive ? "bg-dark-700 hover:bg-dark-600" : "bg-primary-600 hover:bg-primary-700"}`}
        >
          <span class="text-xs md:text-sm font-bold uppercase tracking-widest text-white/90 mb-1">{brand.ctaLabel}</span>
          <span class="text-3xl md:text-4xl font-black tracking-tight flex items-center gap-3 text-white">
            <div class="bg-white text-primary-600 rounded-full p-2 shadow-inner">
              <Phone size={24} strokeWidth={3} />
            </div>
            {brand.phone}
          </span>
        </a>
      </div>
    </div>
  </div>
</header>
