---
import { ArrowRightCircle } from '@lucide/astro';
import { brand } from '~/lib/brand';
import type { CollectionEntry } from 'astro:content';

type Props = {
  services: CollectionEntry<'services'>[];
};

const { services } = Astro.props;
---

<section class="bg-dark py-24 text-white">
  <div class="container-wide px-6 sm:px-10 lg:px-12">
    {/* Section Header matching reference */}
    <div class="mb-16">
      <div class="inline-block bg-black px-4 py-2 mb-4">
        <span class="text-white text-sm font-black uppercase tracking-widest">What we are best at</span>
      </div>
      <div class="flex items-center gap-6">
        <h2 class="text-5xl md:text-7xl font-black uppercase tracking-tighter whitespace-nowrap">Our Services</h2>
        <div class="flex-grow h-0.5 bg-white/20"></div>
      </div>
    </div>

    {/* Services Grid with spacing and individual borders */}
    <div class="flex flex-wrap justify-center gap-10">
      {services.map((s) => {
        // Fallback to brand hero image if no service hero is defined
        const imageUrl = s.data.hero || `${brand.imagesBase}/brand/hero.webp`;
        
        return (
          <a 
            href={`/services/${s.data.service_slug}/`}
            class="group relative h-[350px] w-full md:w-[calc((100%-40px)/2)] lg:w-[calc((100%-80px)/3)] border-4 border-white/10 shadow-2xl overflow-hidden cursor-pointer transform transition-transform hover:-translate-y-2"
          >
            {/* Photo */}
            <img 
              src={imageUrl} 
              alt={s.data.service_display} 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
            />
            
            {/* Image Overlay */}
            <div class="absolute inset-0 bg-black/30 group-hover:bg-black/10 transition-all duration-500"></div>
            
            {/* Bottom banner containing the text box */}
            <div class="absolute bottom-6 left-6 right-6">
              <div class="flex items-center justify-between bg-black text-white px-6 py-5 font-black uppercase text-xl border border-white/10 shadow-xl group-hover:bg-primary-600 transition-colors duration-300">
                <span class="tracking-tighter line-clamp-2">{s.data.service_display}</span>
                <ArrowRightCircle size={32} class="text-primary-500 group-hover:text-white transition-colors shrink-0" />
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
